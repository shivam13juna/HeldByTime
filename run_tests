#!/usr/bin/env bash
# run_tests — Task 1 harness.
#
# Enforces (see app.md §10 step 1, SECURITY_INVARIANTS.md I11):
#   - negative-scope guard: no implementation code has started yet
#   - placeholder scan: no TODO/FIXME/etc. in deliverables
#   - constants consistency: spec/constants.json == Swift == Go == FORMAT.md
#   - no silent skips: a SKIP not in tests/skip-allowlist.txt fails the run
#
# Exit 0 only if every check passes with no unallowed skips.

set -uo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"
BUILD="$ROOT/build"
mkdir -p "$BUILD"
RESULTS="$BUILD/results.txt"
: > "$RESULTS"

emit() {  # emit STATUS NAME [DETAIL...]
  local status="$1"; local name="$2"; shift 2 || true
  local detail="$*"
  if [ -n "$detail" ]; then
    echo "RESULT: $status $name -- $detail" | tee -a "$RESULTS"
  else
    echo "RESULT: $status $name" | tee -a "$RESULTS"
  fi
}

run_exec() {  # run_exec EXE NAME [args...] — run a test binary, collect its RESULT lines
  local exe="$1"; local name="$2"; shift 2
  local out="$BUILD/${name//\//_}.out"
  "$exe" "$@" > "$out" 2>&1
  local code=$?
  grep '^RESULT:' "$out" | tee -a "$RESULTS"
  if [ "$code" -ne 0 ] && ! grep -q '^RESULT: FAIL ' "$out"; then
    emit FAIL "$name/exit" "exited $code with no FAIL result (see $out)"
  fi
}

echo "== vault harness =="

# ---- 1. Phase guard (Task-1 negative-scope retired at Task 2; forward guards kept) ----
scope_ok=1
# UI frameworks are not permitted until Task 9.
if grep -rlE '^[[:space:]]*import[[:space:]]+(SwiftUI|AppKit|Cocoa)' --include='*.swift' Sources Tools tests 2>/dev/null | grep -q .; then
  emit FAIL scope/ui-import "SwiftUI/AppKit/Cocoa import found (forbidden before Task 9)"
  scope_ok=0
fi
# No assembled .app bundle until Task 11.
if find . -path ./.git -prune -o -name '*.app' -print 2>/dev/null | grep -q .; then
  emit FAIL scope/app-bundle ".app bundle present (forbidden before Task 11)"
  scope_ok=0
fi
[ "$scope_ok" = 1 ] && emit PASS scope/phase-guard

# ---- 2. Placeholder scan (our deliverables only; vendored third-party code excluded) ----
PH='(TODO|FIXME|XXX|PLACEHOLDER|HACK)'
PH_SCAN=(grep -rnE "$PH" --exclude-dir=vendor FORMAT.md SECURITY_INVARIANTS.md spec Sources Tools helper tests)
if "${PH_SCAN[@]}" 2>/dev/null | grep -q .; then
  emit FAIL placeholder/scan "placeholder token found in deliverables"
  "${PH_SCAN[@]}" 2>/dev/null | sed 's/^/    /'
else
  emit PASS placeholder/scan
fi

# ---- 3. Build the Swift constant dumper ----
if swiftc -O Sources/Constants/Constants.swift Tools/constdump-swift/main.swift -o "$BUILD/constdump-swift" 2> "$BUILD/swiftc.log"; then
  if "$BUILD/constdump-swift" > "$BUILD/constants-swift.json" 2>> "$BUILD/swiftc.log"; then
    emit PASS build/swift-dumper
  else
    emit FAIL build/swift-dumper "dumper run failed (see build/swiftc.log)"
  fi
else
  emit FAIL build/swift-dumper "swiftc failed (see build/swiftc.log)"
fi

# ---- 4. Build the Go constant dumper ----
if ( cd helper && go build -o "$BUILD/constdump-go" ./cmd/constdump ) 2> "$BUILD/gobuild.log"; then
  if "$BUILD/constdump-go" > "$BUILD/constants-go.json" 2>> "$BUILD/gobuild.log"; then
    emit PASS build/go-dumper
  else
    emit FAIL build/go-dumper "dumper run failed (see build/gobuild.log)"
  fi
else
  emit FAIL build/go-dumper "go build failed (see build/gobuild.log)"
fi

# ---- 5. Constants consistency check ----
if [ -f "$BUILD/constants-swift.json" ] && [ -f "$BUILD/constants-go.json" ]; then
  if swiftc -O tests/consistency_check.swift -o "$BUILD/consistency_check" 2> "$BUILD/cc-build.log"; then
    run_exec "$BUILD/consistency_check" consistency spec/constants.json "$BUILD/constants-swift.json" "$BUILD/constants-go.json" FORMAT.md
  else
    emit FAIL consistency/build "consistency_check failed to compile (see build/cc-build.log)"
  fi
else
  emit FAIL consistency/inputs "dumper outputs missing; cannot run consistency check"
fi

# ---- 5b. Helper (Task 3): vendor integrity + build ----
# The vaultseal helper vendors its drand/tlock dependency tree (pinned, committed).
# Two enforcement points (SECURITY_INVARIANTS I9; Task 3 vendor discipline):
#   - `go mod verify` checks the module hashes match go.sum.
#   - `go build -mod=vendor` fails with "inconsistent vendoring" if vendor/ is
#     missing or out of sync with go.mod -- this IS the dirty-vendor guard.
helper_ok=1
if [ ! -d helper/vendor ] || [ ! -f helper/vendor/modules.txt ]; then
  emit FAIL helper/vendor-present "helper/vendor missing (run: cd helper && go mod vendor)"
  helper_ok=0
fi
if [ "$helper_ok" = 1 ]; then
  if ( cd helper && go mod verify ) > "$BUILD/helper-verify.log" 2>&1; then
    emit PASS helper/mod-verify
  else
    emit FAIL helper/mod-verify "go mod verify failed (see build/helper-verify.log)"
    helper_ok=0
  fi
fi
if [ "$helper_ok" = 1 ]; then
  if ( cd helper \
        && go build -mod=vendor -o "$BUILD/vaultseal" ./cmd/vaultseal \
        && go build -mod=vendor -o "$BUILD/hermetictests" ./cmd/hermetictests \
     ) > "$BUILD/helper-build.log" 2>&1; then
    emit PASS helper/build
  else
    emit FAIL helper/build "vaultseal/hermetictests build failed (see build/helper-build.log)"
    helper_ok=0
  fi
fi

# ---- 5c. Helper hermetic tests (offline: network is black-holed to prove it) ----
# Real-beacon round-trip, fail-closed behaviours, and negative-CLI coverage. The
# proxy env points at a dead address so any accidental network dependence fails
# loudly instead of silently passing against the live drand network.
if [ "$helper_ok" = 1 ] && [ -x "$BUILD/hermetictests" ]; then
  HTTPS_PROXY=http://127.0.0.1:1 HTTP_PROXY=http://127.0.0.1:1 ALL_PROXY=socks5://127.0.0.1:1 \
    run_exec "$BUILD/hermetictests" helper-tests "$BUILD/vaultseal"
else
  emit FAIL helper/tests "skipped because the helper build did not succeed"
fi

# ---- 5d. Helper unit tests (real Network HTTP layer via in-process httptest) ----
if [ "$helper_ok" = 1 ]; then
  if ( cd helper && go test -mod=vendor ./internal/... ) > "$BUILD/helper-gotest.log" 2>&1; then
    emit PASS helper/go-test
  else
    emit FAIL helper/go-test "go test failed (see build/helper-gotest.log)"
    sed 's/^/    /' "$BUILD/helper-gotest.log"
  fi
fi

# ---- 6. Build vendored Argon2id (portable ref build) into a static lib ----
ACFLAGS="-O3 -Ivendor/argon2/include -Ivendor/argon2/src -ISources/CArgon2/include"
ASRC="vendor/argon2/src/argon2.c vendor/argon2/src/core.c vendor/argon2/src/encoding.c \
      vendor/argon2/src/ref.c vendor/argon2/src/thread.c vendor/argon2/src/blake2/blake2b.c \
      Sources/CArgon2/shim.c"
mkdir -p "$BUILD/aobj"
: > "$BUILD/argon2-cc.log"
argon2_ok=1
for f in $ASRC; do
  if ! clang $ACFLAGS -c "$f" -o "$BUILD/aobj/$(basename "${f%.c}").o" 2>> "$BUILD/argon2-cc.log"; then
    argon2_ok=0
  fi
done
if [ "$argon2_ok" = 1 ] && ar rcs "$BUILD/libargon2.a" "$BUILD"/aobj/*.o 2>> "$BUILD/argon2-cc.log"; then
  emit PASS build/argon2-lib
else
  emit FAIL build/argon2-lib "Argon2 C build failed (see build/argon2-cc.log)"
fi

# ---- 7. Build + run the test binary (format + Argon2id + end-to-end) ----
if [ -f "$BUILD/libargon2.a" ] && swiftc -O \
      Sources/Constants/Constants.swift Sources/VaultCore/*.swift \
      tests/test_support.swift tests/format_suite.swift tests/argon2_suite.swift \
      tests/helper_suite.swift tests/schedule_suite.swift tests/store_suite.swift tests/session_suite.swift tests/setup_suite.swift tests/main.swift \
      -I Sources/CArgon2/include -Xcc -Ivendor/argon2/include \
      -L "$BUILD" -largon2 -o "$BUILD/vault_tests" 2> "$BUILD/test-build.log"; then
  run_exec "$BUILD/vault_tests" tests
else
  emit FAIL tests/build "test binary failed to compile (see build/test-build.log)"
fi

# ---- 7b. DEBUG dry-run surface must not leak into a release build (Task 4) ----
# The developer dry-run wrappers (DryRun.swift) are wrapped in #if DEBUG and must
# be ABSENT from release. We compile VaultCore both ways (no linking needed) and
# search the object for the unique sentinel string the wrappers embed:
#   - release build (no -D DEBUG): marker MUST be absent (the shipped surface).
#   - debug build   (-D DEBUG):    marker MUST be present (proves the test bites).
DRYRUN_MARKER='VAULT_DRYRUN_SURFACE_V1'
DRYRUN_SRC=(Sources/Constants/Constants.swift Sources/VaultCore/*.swift)
DRYRUN_INC=(-I Sources/CArgon2/include -Xcc -Ivendor/argon2/include)
dryrun_ok=1
if swiftc -O -wmo -emit-object "${DRYRUN_SRC[@]}" "${DRYRUN_INC[@]}" \
      -o "$BUILD/vaultcore-release.o" 2> "$BUILD/dryrun-release.log"; then
  if strings "$BUILD/vaultcore-release.o" | grep -q "$DRYRUN_MARKER"; then
    emit FAIL dryrun/release-leak "dry-run marker present in release build"
    dryrun_ok=0
  fi
else
  emit FAIL dryrun/release-build "release VaultCore failed to compile (see build/dryrun-release.log)"
  dryrun_ok=0
fi
if swiftc -wmo -emit-object -D DEBUG "${DRYRUN_SRC[@]}" "${DRYRUN_INC[@]}" \
      -o "$BUILD/vaultcore-debug.o" 2> "$BUILD/dryrun-debug.log"; then
  if ! strings "$BUILD/vaultcore-debug.o" | grep -q "$DRYRUN_MARKER"; then
    emit FAIL dryrun/debug-missing "dry-run marker absent in DEBUG build (gate is vacuous)"
    dryrun_ok=0
  fi
else
  emit FAIL dryrun/debug-build "debug VaultCore failed to compile (see build/dryrun-debug.log)"
  dryrun_ok=0
fi
[ "$dryrun_ok" = 1 ] && emit PASS dryrun/release-gate

# ---- Aggregate ----
echo
echo "== Summary =="
fail_count=$(grep -c '^RESULT: FAIL ' "$RESULTS" || true)
pass_count=$(grep -c '^RESULT: PASS ' "$RESULTS" || true)
ALLOW="tests/skip-allowlist.txt"
skip_unallowed=0
while IFS= read -r line; do
  [ -z "$line" ] && continue
  name=$(echo "$line" | awk '{print $3}')
  if ! grep -qxF "$name" "$ALLOW" 2>/dev/null; then
    echo "  unallowed SKIP: $name"
    skip_unallowed=$((skip_unallowed + 1))
  fi
done < <(grep '^RESULT: SKIP ' "$RESULTS" 2>/dev/null || true)

echo "  PASS=$pass_count  FAIL=$fail_count  SKIP-unallowed=$skip_unallowed"
if [ "$fail_count" -eq 0 ] && [ "$skip_unallowed" -eq 0 ]; then
  echo "OK: harness green."
  exit 0
else
  echo "FAILED: harness is red."
  exit 1
fi
