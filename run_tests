#!/usr/bin/env bash
# run_tests — Task 1 harness.
#
# Enforces (see app.md §10 step 1, SECURITY_INVARIANTS.md I11):
#   - negative-scope guard: no implementation code has started yet
#   - placeholder scan: no TODO/FIXME/etc. in deliverables
#   - constants consistency: spec/constants.json == Swift == Go == FORMAT.md
#   - no silent skips: a SKIP not in tests/skip-allowlist.txt fails the run
#
# Exit 0 only if every check passes with no unallowed skips.

set -uo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"
BUILD="$ROOT/build"
mkdir -p "$BUILD"
RESULTS="$BUILD/results.txt"
: > "$RESULTS"

emit() {  # emit STATUS NAME [DETAIL...]
  local status="$1"; local name="$2"; shift 2 || true
  local detail="$*"
  if [ -n "$detail" ]; then
    echo "RESULT: $status $name -- $detail" | tee -a "$RESULTS"
  else
    echo "RESULT: $status $name" | tee -a "$RESULTS"
  fi
}

run_exec() {  # run_exec EXE NAME [args...] — run a test binary, collect its RESULT lines
  local exe="$1"; local name="$2"; shift 2
  local out="$BUILD/${name//\//_}.out"
  "$exe" "$@" > "$out" 2>&1
  local code=$?
  grep '^RESULT:' "$out" | tee -a "$RESULTS"
  if [ "$code" -ne 0 ] && ! grep -q '^RESULT: FAIL ' "$out"; then
    emit FAIL "$name/exit" "exited $code with no FAIL result (see $out)"
  fi
}

echo "== vault harness =="

# ---- 1. Phase guard (Task-1 negative-scope retired at Task 2; forward guards kept) ----
scope_ok=1
# UI frameworks are permitted ONLY in the Sources/VaultApp UI layer (Task 9+).
# The engine core (VaultCore/Constants), tooling, and tests must stay SwiftUI-free
# so the security logic remains headless and unit-testable; this guard still bites
# everywhere except VaultApp.
if grep -rlE '^[[:space:]]*import[[:space:]]+(SwiftUI|AppKit|Cocoa)' --include='*.swift' --exclude-dir=VaultApp Sources Tools tests 2>/dev/null | grep -q .; then
  emit FAIL scope/ui-import "SwiftUI/AppKit/Cocoa import found outside Sources/VaultApp (only the UI layer may import them)"
  scope_ok=0
fi
# No assembled .app bundle in the COMMITTED source tree. From Task 11 the official
# build.sh assembles one under build/ (gitignored, ephemeral), so that path is
# excluded — but a .app anywhere in the tracked sources is still forbidden.
if find . -path ./.git -prune -o -path ./build -prune -o -name '*.app' -print 2>/dev/null | grep -q .; then
  emit FAIL scope/app-bundle ".app bundle present in the source tree (build artifacts belong under build/)"
  scope_ok=0
fi
[ "$scope_ok" = 1 ] && emit PASS scope/phase-guard

# ---- 2. Placeholder scan (our deliverables only; vendored third-party code excluded) ----
PH='(TODO|FIXME|XXX|PLACEHOLDER|HACK)'
PH_SCAN=(grep -rnE "$PH" --exclude-dir=vendor FORMAT.md SECURITY_INVARIANTS.md spec Sources Tools helper tests)
if "${PH_SCAN[@]}" 2>/dev/null | grep -q .; then
  emit FAIL placeholder/scan "placeholder token found in deliverables"
  "${PH_SCAN[@]}" 2>/dev/null | sed 's/^/    /'
else
  emit PASS placeholder/scan
fi

# ---- 3. Build the Swift constant dumper ----
if swiftc -O Sources/Constants/Constants.swift Tools/constdump-swift/main.swift -o "$BUILD/constdump-swift" 2> "$BUILD/swiftc.log"; then
  if "$BUILD/constdump-swift" > "$BUILD/constants-swift.json" 2>> "$BUILD/swiftc.log"; then
    emit PASS build/swift-dumper
  else
    emit FAIL build/swift-dumper "dumper run failed (see build/swiftc.log)"
  fi
else
  emit FAIL build/swift-dumper "swiftc failed (see build/swiftc.log)"
fi

# ---- 4. Build the Go constant dumper ----
if ( cd helper && go build -o "$BUILD/constdump-go" ./cmd/constdump ) 2> "$BUILD/gobuild.log"; then
  if "$BUILD/constdump-go" > "$BUILD/constants-go.json" 2>> "$BUILD/gobuild.log"; then
    emit PASS build/go-dumper
  else
    emit FAIL build/go-dumper "dumper run failed (see build/gobuild.log)"
  fi
else
  emit FAIL build/go-dumper "go build failed (see build/gobuild.log)"
fi

# ---- 5. Constants consistency check ----
if [ -f "$BUILD/constants-swift.json" ] && [ -f "$BUILD/constants-go.json" ]; then
  if swiftc -O tests/consistency_check.swift -o "$BUILD/consistency_check" 2> "$BUILD/cc-build.log"; then
    run_exec "$BUILD/consistency_check" consistency spec/constants.json "$BUILD/constants-swift.json" "$BUILD/constants-go.json" FORMAT.md
  else
    emit FAIL consistency/build "consistency_check failed to compile (see build/cc-build.log)"
  fi
else
  emit FAIL consistency/inputs "dumper outputs missing; cannot run consistency check"
fi

# ---- 5b. Helper (Task 3): vendor integrity + build ----
# The vaultseal helper vendors its drand/tlock dependency tree (pinned, committed).
# Two enforcement points (SECURITY_INVARIANTS I9; Task 3 vendor discipline):
#   - `go mod verify` checks the module hashes match go.sum.
#   - `go build -mod=vendor` fails with "inconsistent vendoring" if vendor/ is
#     missing or out of sync with go.mod -- this IS the dirty-vendor guard.
helper_ok=1
if [ ! -d helper/vendor ] || [ ! -f helper/vendor/modules.txt ]; then
  emit FAIL helper/vendor-present "helper/vendor missing (run: cd helper && go mod vendor)"
  helper_ok=0
fi
if [ "$helper_ok" = 1 ]; then
  if ( cd helper && go mod verify ) > "$BUILD/helper-verify.log" 2>&1; then
    emit PASS helper/mod-verify
  else
    emit FAIL helper/mod-verify "go mod verify failed (see build/helper-verify.log)"
    helper_ok=0
  fi
fi
if [ "$helper_ok" = 1 ]; then
  if ( cd helper \
        && go build -mod=vendor -o "$BUILD/vaultseal" ./cmd/vaultseal \
        && go build -mod=vendor -o "$BUILD/hermetictests" ./cmd/hermetictests \
     ) > "$BUILD/helper-build.log" 2>&1; then
    emit PASS helper/build
  else
    emit FAIL helper/build "vaultseal/hermetictests build failed (see build/helper-build.log)"
    helper_ok=0
  fi
fi

# ---- 5c. Helper hermetic tests (offline: network is black-holed to prove it) ----
# Real-beacon round-trip, fail-closed behaviours, and negative-CLI coverage. The
# proxy env points at a dead address so any accidental network dependence fails
# loudly instead of silently passing against the live drand network.
if [ "$helper_ok" = 1 ] && [ -x "$BUILD/hermetictests" ]; then
  HTTPS_PROXY=http://127.0.0.1:1 HTTP_PROXY=http://127.0.0.1:1 ALL_PROXY=socks5://127.0.0.1:1 \
    run_exec "$BUILD/hermetictests" helper-tests "$BUILD/vaultseal"
else
  emit FAIL helper/tests "skipped because the helper build did not succeed"
fi

# ---- 5d. Helper unit tests (real Network HTTP layer via in-process httptest) ----
if [ "$helper_ok" = 1 ]; then
  if ( cd helper && go test -mod=vendor ./internal/... ) > "$BUILD/helper-gotest.log" 2>&1; then
    emit PASS helper/go-test
  else
    emit FAIL helper/go-test "go test failed (see build/helper-gotest.log)"
    sed 's/^/    /' "$BUILD/helper-gotest.log"
  fi
fi

# ---- 6. Build vendored Argon2id (portable ref build) into a static lib ----
ACFLAGS="-O3 -Ivendor/argon2/include -Ivendor/argon2/src -ISources/CArgon2/include"
ASRC="vendor/argon2/src/argon2.c vendor/argon2/src/core.c vendor/argon2/src/encoding.c \
      vendor/argon2/src/ref.c vendor/argon2/src/thread.c vendor/argon2/src/blake2/blake2b.c \
      Sources/CArgon2/shim.c"
mkdir -p "$BUILD/aobj"
: > "$BUILD/argon2-cc.log"
argon2_ok=1
for f in $ASRC; do
  if ! clang $ACFLAGS -c "$f" -o "$BUILD/aobj/$(basename "${f%.c}").o" 2>> "$BUILD/argon2-cc.log"; then
    argon2_ok=0
  fi
done
if [ "$argon2_ok" = 1 ] && ar rcs "$BUILD/libargon2.a" "$BUILD"/aobj/*.o 2>> "$BUILD/argon2-cc.log"; then
  emit PASS build/argon2-lib
else
  emit FAIL build/argon2-lib "Argon2 C build failed (see build/argon2-cc.log)"
fi

# ---- 7. Build + run the test binary (format + Argon2id + end-to-end) ----
if [ -f "$BUILD/libargon2.a" ] && swiftc -O \
      Sources/Constants/Constants.swift Sources/VaultCore/*.swift \
      tests/test_support.swift tests/format_suite.swift tests/argon2_suite.swift \
      tests/helper_suite.swift tests/schedule_suite.swift tests/store_suite.swift tests/session_suite.swift tests/setup_suite.swift tests/ui_suite.swift tests/hardening_suite.swift tests/main.swift \
      -I Sources/CArgon2/include -Xcc -Ivendor/argon2/include \
      -L "$BUILD" -largon2 -o "$BUILD/vault_tests" 2> "$BUILD/test-build.log"; then
  run_exec "$BUILD/vault_tests" tests
else
  emit FAIL tests/build "test binary failed to compile (see build/test-build.log)"
fi

# ---- 7b. DEBUG dry-run surface must not leak into a release build (Task 4) ----
# The developer dry-run wrappers (DryRun.swift) are wrapped in #if DEBUG and must
# be ABSENT from release. We compile VaultCore both ways (no linking needed) and
# search the object for the unique sentinel string the wrappers embed:
#   - release build (no -D DEBUG): marker MUST be absent (the shipped surface).
#   - debug build   (-D DEBUG):    marker MUST be present (proves the test bites).
DRYRUN_MARKER='VAULT_DRYRUN_SURFACE_V1'
DRYRUN_SRC=(Sources/Constants/Constants.swift Sources/VaultCore/*.swift)
DRYRUN_INC=(-I Sources/CArgon2/include -Xcc -Ivendor/argon2/include)
dryrun_ok=1
if swiftc -O -wmo -emit-object "${DRYRUN_SRC[@]}" "${DRYRUN_INC[@]}" \
      -o "$BUILD/vaultcore-release.o" 2> "$BUILD/dryrun-release.log"; then
  if strings "$BUILD/vaultcore-release.o" | grep -q "$DRYRUN_MARKER"; then
    emit FAIL dryrun/release-leak "dry-run marker present in release build"
    dryrun_ok=0
  fi
else
  emit FAIL dryrun/release-build "release VaultCore failed to compile (see build/dryrun-release.log)"
  dryrun_ok=0
fi
if swiftc -wmo -emit-object -D DEBUG "${DRYRUN_SRC[@]}" "${DRYRUN_INC[@]}" \
      -o "$BUILD/vaultcore-debug.o" 2> "$BUILD/dryrun-debug.log"; then
  if ! strings "$BUILD/vaultcore-debug.o" | grep -q "$DRYRUN_MARKER"; then
    emit FAIL dryrun/debug-missing "dry-run marker absent in DEBUG build (gate is vacuous)"
    dryrun_ok=0
  fi
else
  emit FAIL dryrun/debug-build "debug VaultCore failed to compile (see build/dryrun-debug.log)"
  dryrun_ok=0
fi
[ "$dryrun_ok" = 1 ] && emit PASS dryrun/release-gate

# ---- 7c. UI layer type-checks against VaultCore + SwiftUI (Task 9) ----
# SwiftUI views can't run headless and the .app isn't assembled until Task 11, so
# the gate here is a full TYPE-CHECK: the Sources/VaultApp layer must compile
# against the real engine APIs (FirstRunSetup / VaultStore / VaultSession) and
# SwiftUI/AppKit. This catches UI↔engine wiring drift every run without producing
# or executing a bundle. `-parse-as-library` is required because VaultApp.swift
# uses the @main attribute.
if swiftc -typecheck -parse-as-library \
      Sources/Constants/Constants.swift Sources/VaultCore/*.swift \
      Sources/VaultApp/*.swift Sources/VaultApp/Views/*.swift \
      -I Sources/CArgon2/include -Xcc -Ivendor/argon2/include 2> "$BUILD/ui-typecheck.log"; then
  emit PASS ui/typecheck
else
  emit FAIL ui/typecheck "Sources/VaultApp failed to type-check (see build/ui-typecheck.log)"
  sed 's/^/    /' "$BUILD/ui-typecheck.log"
fi

# ---- 7d. No-durable-plaintext leak guard (Task 10; app.md §9, SECURITY_INVARIANTS I13) ----
# Static guard for the leak surfaces that are AppKit/UI (so can't run headless).
# The one OS-level piece (core dumps) is also unit-tested in hardening_suite.swift.
leak_ok=1
# (a) SwiftUI TextEditor cannot disable spellcheck/data-detectors/undo, so it must
#     NOT hold vault text — free-text fields drop to the hardened NSTextView wrapper.
# (\bTextEditor so it does NOT match our own HardenedTextEditor.)
if grep -rnE '\bTextEditor\(' Sources/VaultApp 2>/dev/null | grep -q .; then
  emit FAIL leak/texteditor "SwiftUI TextEditor() in VaultApp — use HardenedTextEditor (TextEditor can't disable spellcheck/undo/data-detectors)"
  grep -rnE '\bTextEditor\(' Sources/VaultApp 2>/dev/null | sed 's/^/    /'
  leak_ok=0
fi
# (b) The hardened text view must disable every text-intelligence service that can
#     ship plaintext to a system service / on-disk cache, plus undo persistence.
HARD="Sources/VaultApp/Views/HardenedText.swift"
for flag in isContinuousSpellCheckingEnabled isGrammarCheckingEnabled \
            isAutomaticSpellingCorrectionEnabled isAutomaticDataDetectionEnabled \
            isAutomaticLinkDetectionEnabled isAutomaticTextReplacementEnabled \
            isAutomaticQuoteSubstitutionEnabled isAutomaticDashSubstitutionEnabled \
            smartInsertDeleteEnabled allowsUndo; do
  if ! grep -q "$flag = false" "$HARD" 2>/dev/null; then
    emit FAIL leak/hardening-flag "$flag not disabled in $(basename "$HARD")"
    leak_ok=0
  fi
done
# (c) Core dumps disabled at launch (a core file would be durable plaintext).
if ! grep -rq 'setrlimit(RLIMIT_CORE' Sources/VaultCore Sources/VaultApp 2>/dev/null; then
  emit FAIL leak/core-dumps "no setrlimit(RLIMIT_CORE,...) — core dumps not disabled"
  leak_ok=0
fi
# (d) Saved Application State / window restoration off (it can persist editor text).
if ! grep -rq 'NSQuitAlwaysKeepsWindows' Sources/VaultApp 2>/dev/null; then
  emit FAIL leak/state-restoration "app does not disable Saved Application State (NSQuitAlwaysKeepsWindows)"
  leak_ok=0
fi
# (e) No secret logging anywhere in the engine/UI. The only permitted stderr writer
#     is the DEBUG-only dry-run surface (DryRun.swift, gated by step 7b).
if grep -rnE '\b(print|debugPrint|NSLog|os_log)[[:space:]]*\(' --include='*.swift' \
      Sources/VaultCore Sources/VaultApp 2>/dev/null | grep -v '/DryRun.swift' | grep -q .; then
  emit FAIL leak/logging "print/NSLog/os_log in engine/UI (potential secret leak)"
  grep -rnE '\b(print|debugPrint|NSLog|os_log)[[:space:]]*\(' --include='*.swift' \
      Sources/VaultCore Sources/VaultApp 2>/dev/null | grep -v '/DryRun.swift' | sed 's/^/    /'
  leak_ok=0
fi
# (f) The password reveal must stay hardened: RevealableSecureField's shown state
#     uses the hardened HardenedTextEditor, never a bare SwiftUI TextField (which
#     would route the cleartext password through the unhardened field editor).
#     SecureField/HardenedTextEditor don't contain the substring "TextField(", so
#     any bare TextField( in HardenedText.swift is a regression of this property.
if grep -qE '\bTextField\(' "$HARD" 2>/dev/null; then
  emit FAIL leak/reveal-hardening "bare TextField( in $(basename "$HARD") — the reveal field must keep its shown state on HardenedTextEditor (no unhardened field editor for the password)"
  leak_ok=0
fi
if ! grep -q 'HardenedTextEditor(text:' "$HARD" 2>/dev/null; then
  emit FAIL leak/reveal-hardening "RevealableSecureField no longer routes its revealed state through HardenedTextEditor"
  leak_ok=0
fi
[ "$leak_ok" = 1 ] && emit PASS leak/guard

# ---- 7e. build.sh bundling-gate lint (Task 11; app.md §10 step 13, §11) ----
# build.sh assembles + signs the .app and can't be run from inside the gate (it
# RUNS this harness, and a full GUI build + codesign is not a fast headless check).
# So this is a STATIC guard on the security-critical ORDERING + steps of build.sh;
# the empirical proof is producing a real, codesign-verified bundle by running it.
build_ok=1
BS="build.sh"
if [ ! -x "$BS" ]; then
  emit FAIL build/script-present "build.sh missing or not executable"
  build_ok=0
else
  # (a) GATE-FIRST: ./run_tests must appear before the first codesign invocation —
  #     the bundle is never signed/assembled unless the harness passed.
  gate_line=$(grep -nE '\./run_tests' "$BS" | head -1 | cut -d: -f1)
  sign_line=$(grep -nE '^[[:space:]]*codesign' "$BS" | head -1 | cut -d: -f1)
  if [ -z "$gate_line" ] || [ -z "$sign_line" ] || [ "$gate_line" -ge "$sign_line" ]; then
    emit FAIL build/gate-first "build.sh must run ./run_tests before any codesign (gate=$gate_line sign=$sign_line)"
    build_ok=0
  fi
  # (b) NESTED-FIRST: the embedded helper is signed before the bundle is sealed.
  #     Both signing lines use `codesign --force`; the verify step uses --verify, so
  #     it does not match. head -1 of each gives the signing line.
  helper_sign=$(grep -nE '^[[:space:]]*codesign --force.*HELPERS_DIR/vaultseal' "$BS" | head -1 | cut -d: -f1)
  bundle_sign=$(grep -nE '^[[:space:]]*codesign --force.*"\$APP"' "$BS" | head -1 | cut -d: -f1)
  if [ -z "$helper_sign" ] || [ -z "$bundle_sign" ] || [ "$helper_sign" -ge "$bundle_sign" ]; then
    emit FAIL build/nested-sign-first "build.sh must sign the nested helper before the bundle (helper=$helper_sign bundle=$bundle_sign)"
    build_ok=0
  fi
  # (c) Required verification + release-surface steps are present.
  for needle in 'codesign --verify --deep --strict' 'otool -L' "$DRYRUN_MARKER" 'shasum -a 256' 'plutil -lint'; do
    if ! grep -qF "$needle" "$BS"; then
      emit FAIL build/step-missing "build.sh is missing a required step: $needle"
      build_ok=0
    fi
  done
  # (d) The helper hash is compiled in (not a writable sidecar): the app must source
  #     its expected hash from BundledHelper.sha256, and build.sh must inject it there.
  if ! grep -qF 'BundledHelper.sha256' Sources/VaultApp/AppConfiguration.swift; then
    emit FAIL build/hash-compiled-in "AppConfiguration must use BundledHelper.sha256 as the expected helper hash"
    build_ok=0
  fi
  if ! grep -qF 'BundledHelper.swift' "$BS"; then
    emit FAIL build/hash-injected "build.sh must inject the helper digest into BundledHelper.swift"
    build_ok=0
  fi
fi
[ "$build_ok" = 1 ] && emit PASS build/bundling-gate

# ---- 7f. Live E2E harness-gate lint (Task 12; app.md §10 step 14, §11) ----
# The live E2E (./e2e_test) needs the network + minutes of real time, so it can't
# run inside this offline harness. This is the STATIC fence that its deliverables
# exist and still cover the required legs against the REAL helper (not FakeSeal);
# the empirical proof is running ./e2e_test online + the GUI checklist in E2E.md.
e2e_ok=1
E2E_MAIN="tests/e2e/main.swift"
for f in e2e_test Tools/scan_leak.sh; do
  if [ ! -x "$f" ]; then emit FAIL e2e/script-present "$f missing or not executable"; e2e_ok=0; fi
done
for f in "$E2E_MAIN" E2E.md; do
  if [ ! -f "$f" ]; then emit FAIL e2e/file-present "$f missing"; e2e_ok=0; fi
done
if [ -f "$E2E_MAIN" ]; then
  # (a) Drives the REAL helper path — HelperRunner + VaultSealClient — and must NOT
  #     fall back to the offline FakeSeal (that would make "live" a lie).
  if ! grep -qF 'HelperRunner(' "$E2E_MAIN" || ! grep -qF 'VaultSealClient(' "$E2E_MAIN"; then
    emit FAIL e2e/real-helper "$E2E_MAIN must drive the real HelperRunner/VaultSealClient"
    e2e_ok=0
  fi
  if grep -qF 'FakeSeal(' "$E2E_MAIN"; then
    emit FAIL e2e/no-fakeseal "$E2E_MAIN must not instantiate FakeSeal — the E2E is the LIVE path"
    e2e_ok=0
  fi
  # (b) Still covers each required leg (the RESULT names the checklist depends on).
  for needle in 'e2e/locked-before-window' 'e2e/opens-at-round' 'e2e/interactive-reseal-forward' \
                'e2e/defensive-reseal' 'e2e/offline-failclosed' 'e2e/no-plaintext'; do
    if ! grep -qF "$needle" "$E2E_MAIN"; then
      emit FAIL e2e/leg-missing "$E2E_MAIN no longer covers leg: $needle"
      e2e_ok=0
    fi
  done
fi
# (c) The runner compiles the E2E against the REAL engine (not a stub copy).
if [ -f e2e_test ]; then
  if ! grep -qF 'Sources/VaultCore/*.swift' e2e_test || ! grep -qF "$E2E_MAIN" e2e_test; then
    emit FAIL e2e/runner-wires-engine "e2e_test must compile $E2E_MAIN with Sources/VaultCore"
    e2e_ok=0
  fi
fi
[ "$e2e_ok" = 1 ] && emit PASS e2e/harness-gate

# ---- Aggregate ----
echo
echo "== Summary =="
fail_count=$(grep -c '^RESULT: FAIL ' "$RESULTS" || true)
pass_count=$(grep -c '^RESULT: PASS ' "$RESULTS" || true)
ALLOW="tests/skip-allowlist.txt"
skip_unallowed=0
while IFS= read -r line; do
  [ -z "$line" ] && continue
  name=$(echo "$line" | awk '{print $3}')
  if ! grep -qxF "$name" "$ALLOW" 2>/dev/null; then
    echo "  unallowed SKIP: $name"
    skip_unallowed=$((skip_unallowed + 1))
  fi
done < <(grep '^RESULT: SKIP ' "$RESULTS" 2>/dev/null || true)

echo "  PASS=$pass_count  FAIL=$fail_count  SKIP-unallowed=$skip_unallowed"
if [ "$fail_count" -eq 0 ] && [ "$skip_unallowed" -eq 0 ]; then
  echo "OK: harness green."
  exit 0
else
  echo "FAILED: harness is red."
  exit 1
fi
